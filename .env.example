OPENAI_API_KEY=your-openapi-key-here
ADZUNA_APP_ID=adzuna_app_id
ADZUNA_APP_KEY=adzuna_app_key
# Neon Cloud connection string — get it from https://neon.tech (project dashboard -> Connect)
DATABASE_URL=postgresql://USER:PASSWORD@ep-your-endpoint.region.aws.neon.tech/neondb?sslmode=require
# Vector search runs on Neon via pgvector — no separate vector DB keys required.

# JWT signing secret for user auth — set a long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-string
# JWT_EXPIRE_MINUTES=1440

# --- Optional: automatic background job sync (leave unset to disable) ---
# JOB_SYNC_QUERIES=backend engineer;python developer
# JOB_SYNC_INTERVAL_HOURS=6
# JOB_SYNC_COUNTRY=gb

# --- Optional: production hardening ---
# API_KEY=generate-a-long-random-string     # enables X-API-Key auth on all endpoints
# RATE_LIMIT_PER_MINUTE=60                  # per-IP request cap (default 60)
# CORS_ORIGINS=https://your-frontend.com    # comma-separated allowed origins